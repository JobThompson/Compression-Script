# Folder containing the source video files to compress
INPUT_DIR=/path/to/input/folder

# Folder where compressed video files will be saved
OUTPUT_DIR=/path/to/output/folder

# CRF (Constant Rate Factor) value for H.265 compression (lower = better quality, larger file)
# Recommended range: 24-30 (default: 28)
CRF=28

# Timeout in seconds for each ffmpeg run (default: 36000 = 10 hours)
# Set to 0 to disable timeout (recommended for very large files)
TIMEOUT_SECONDS=36000

# Output container format: source, mkv, mp4, avi (default: source)
# source keeps each input file's original extension.
OUTPUT_FORMAT=source

# x265 encoding preset for mkv/mp4 outputs.
# Faster presets are quicker but may reduce compression efficiency.
# Options: ultrafast, superfast, veryfast, faster, fast, medium, slow, slower, veryslow, placebo
ENCODER_PRESET=medium
