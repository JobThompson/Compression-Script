# Folder containing the source video files to compress
INPUT_DIR=/path/to/input/folder

# Folder where compressed video files will be saved
OUTPUT_DIR=/path/to/output/folder

# CRF (Constant Rate Factor) value for H.265 compression (lower = better quality, larger file)
# Recommended range: 24-30 (default: 28)
CRF=28

# Timeout in seconds for each ffmpeg run (default: 36000 = 10 hours)
TIMEOUT_SECONDS=36000
